# ============================================================================
# .dockerignore — Otimiza contexto de build do Docker
# ============================================================================
# Reduz contexto de ~1GB para <50MB, acelerando builds e reduzindo uso de RAM
# ============================================================================

# Dependências (serão instaladas no container)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output (sempre reconstruído no container)
.next/
out/

# Documentação (desnecessária em runtime)
*.md
docs/

# Git e controle de versão
.git
.gitignore
.husky/
.gitleaks.toml

# Testes
e2e/
tests/
test-results/
playwright-report/
coverage/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
__mocks__/
jest.config.js
playwright.config.ts
tsconfig.test.json

# Storybook
*.stories.ts
*.stories.tsx

# IDEs e ferramentas de desenvolvimento
.vscode/
.idea/
.cursor/
.cursorignore
.claude/
.codex/
.agents/
.gemini/
.kiro/
.opencode/
.shared/
.superpowers/
.worktrees/
*.swp
*.swo
*~
.DS_Store
.hintrc

# Configurações de desenvolvimento
.editorconfig
.eslintcache
.npmrc
.nvmrc
tsconfig.tsbuildinfo

# Logs
logs/
*.log
pnpm-debug.log*

# Temporários
tmp/
temp/
*.tmp

# Análise e debug
analyze/
*.heapprofile
*.cpuprofile

# Variáveis de ambiente (configuradas no runtime)
.env*
!.env.example

# Docker e infraestrutura (não necessários dentro do container)
Dockerfile*
!Dockerfile
docker-compose*.yml
docker/
.dockerignore
captain-definition

# CI/CD
.github/
.gitlab-ci.yml

# Banco de dados e migrations
supabase/

# Outros arquivos desnecessários em runtime
*.pem
.mcp.json
eslint.config.mjs
eslint-rules/
scripts/
