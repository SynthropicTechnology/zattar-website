# =============================================================================
# ZATTAR ADVOGADOS WEBSITE — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores
#
# cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Obrigatórias)
# -----------------------------------------------------------------------------
# URL pública do projeto — encontre em: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon/publishable — pública, usada no browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=sua_anon_key

# Chave service_role — secreta, usada apenas em server-side
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# (Opcional) Para a API de Management do Supabase (métricas de infra)
# SUPABASE_PROJECT_REF=seu_project_ref
# SUPABASE_ACCESS_TOKEN=seu_access_token

# -----------------------------------------------------------------------------
# REDIS — Rate limiting do formulário de contato (Obrigatório)
# -----------------------------------------------------------------------------
# URL de conexão (ex: redis://localhost:6379 ou rediss://user:pass@host:6380)
REDIS_URL=redis://localhost:6379

# Senha (opcional, inclua aqui se não estiver na URL)
# REDIS_PASSWORD=sua_senha_redis

# Habilita cache Redis além do rate-limit (padrão: true)
ENABLE_REDIS_CACHE=true

# -----------------------------------------------------------------------------
# STRAPI CMS — Conteúdo do blog / insights (Opcional)
# -----------------------------------------------------------------------------
# URL base da instância Strapi (sem barra no final)
STRAPI_URL=https://cms.zattaradvogados.com.br

# Token de leitura gerado em: Strapi Admin > Settings > API Tokens
STRAPI_API_TOKEN=seu_token_strapi

# -----------------------------------------------------------------------------
# SITE
# -----------------------------------------------------------------------------
# URL canônica — usada em links absolutos, sitemap e OG tags
NEXT_PUBLIC_WEBSITE_URL=https://zattaradvogados.com.br

# -----------------------------------------------------------------------------
# CSP / Segurança (Opcional — avançado)
# -----------------------------------------------------------------------------
# Habilita CSP em modo desenvolvimento (padrão: false)
# ENABLE_CSP_IN_DEV=false

# Coloca CSP em modo report-only (padrão: false = enforcement, fail-closed).
# Setar como "true" apenas durante janela de observação inicial em prod —
# a CSP fica logando violações em /api/csp-report sem bloquear nada.
# Após validar reports, remova esta variável (ou setar "false") para ativar
# bloqueio real.
# CSP_REPORT_ONLY=true

# Endpoint de relatório de violações CSP
# CSP_REPORT_URI=/api/csp-report

# Ativa logs verbose do Supabase (padrão: false)
# DEBUG_SUPABASE=false

# -----------------------------------------------------------------------------
# BUILD / CI (Opcional)
# -----------------------------------------------------------------------------
# Ignora erros de TypeScript durante o build (use com cuidado)
# SKIP_TYPE_CHECK=false
